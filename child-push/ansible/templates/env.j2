# this file contains the environment variables for ODA

# oda configuration mode
oda_mode={{ oda_mode }}

# exposed ports
api_gateway_port={{ api_gateway_port }}
web_data_transformer_port={{ web_data_transformer_port }}
data_transformer_port={{ data_transformer_port }}
kafka_port={{ kafka_port }}
kafka_port_static={{ kafka_port_static }}

# host address to reach kafka broker 
kafka_address={{ kafka_address }}
kafka_address_static={{ kafka_address_static }}

# internal docker ports
db_port={{ db_port }}
db_manager_port={{ db_manager_port }}
kafka_internal_port={{ kafka_internal_port }}
topic_manager_port={{ topic_manager_port }}
query_aggregator_port={{ query_aggregator_port }}

# variable to restore the topic list from file in the topic manager
restore_topics_from_file={{ restore_topics_from_file }}

{% if oda_mode == 'child' %}
# mirrormaker root variables
root_kafka_address={{ root_kafka_address }}
root_kafka_port={{ root_kafka_port }}
{% endif %}